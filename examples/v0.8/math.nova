// ======================================================
// NOVA BUILT-IN MATHEMATICAL FUNCTIONS TEST
// ======================================================

User: M = {
    name: S,
    age: N,
    scores: [N]
}

user: User = {
    name = "Varun",
    age = 19,
    scores = [
        85,
        90,
        95
    ]
}

// ======================================================
// BASIC
// ======================================================

print(
    abs(-15)
)

print(
    min(
        10,
        20
    )
)

print(
    max(
        10,
        20
    )
)

print(
    pow(
        2,
        10
    )
)

print(
    sqrt(25)
)

print(
    round(4.7)
)

print(
    floor(4.9)
)

print(
    ceil(4.1)
)

// ======================================================
// ARRAYS
// ======================================================

numbers: [N] = [

    12,

    -8,

    50,

    3,

    100

]

print(numbers)

print(
    abs(
        numbers[1]
    )
)

print(
    max(
        numbers[0],
        numbers[4]
    )
)

print(
    min(
        numbers[2],
        numbers[3]
    )
)

// ======================================================
// MAPS
// ======================================================

print(
    abs(
        user.age
    )
)

print(
    max(
        user.scores[0],
        user.scores[2]
    )
)

print(
    min(
        user.scores[0],
        user.scores[2]
    )
)

// ======================================================
// FUNCTIONS
// ======================================================

fn square(
    value: N
) -> N {

    return pow(
        value,
        2
    )

}

fn distance(
    x: N,
    y: N
) -> N {

    return sqrt(

        square(x)

        +

        square(y)

    )

}

print(
    square(8)
)

print(
    distance(
        3,
        4
    )
)

// ======================================================
// RECURSION
// ======================================================

fn factorial(
    n: N
) -> N {

    if n <= 1 {

        return 1

    }

    return n * factorial(
        n - 1
    )

}

print(

    max(

        factorial(5),

        100

    )

)

print(

    min(

        factorial(3),

        factorial(4)

    )

)

// ======================================================
// DEEP EXPRESSIONS
// ======================================================

print(

    sqrt(

        pow(

            max(

                3,

                min(
                    10,
                    8
                )

            ),

            2

        )

    )

)

print(

    round(

        sqrt(

            pow(
                5,
                2
            )

        )

    )

)

// ======================================================
// LOOPS
// ======================================================

for value in numbers {

    print(

        abs(value)

    )

}

for i in 1...5 {

    print(

        pow(
            i,
            2
        )

    )

}

counter: N = 1

while counter <= 5 {

    print(

        sqrt(

            pow(
                counter,
                2
            )

        )

    )

    counter = counter + 1

}

// ======================================================
// TERNARY
// ======================================================

print(

    max(
        10,
        20
    ) == 20

        ? abs(-999)

        : 0

)

print(

    min(
        5,
        2
    ) == 2

        ? sqrt(81)

        : 0

)

// ======================================================
// VERY DEEP NESTING
// ======================================================

print(

    ceil(

        sqrt(

            pow(

                max(

                    abs(-8),

                    min(

                        12,

                        20

                    )

                ),

                2

            )

        )

    )

)

print(

    floor(

        sqrt(

            pow(

                max(

                    min(
                        50,
                        10
                    ),

                    abs(-7)

                ),

                2

            )

        )

    )

)

// ======================================================
// RANDOM
// ======================================================

print(
    random()
)

print(
    random()
)

print(
    random()
)

